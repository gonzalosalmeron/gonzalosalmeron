---
import Clock from '@/components/Clock'

const links = [
  {
    name: 'Aboute me',
    link: '#aboutme'
  },
  {
    name: 'Proyects',
    link: '#proyects'
  },
  {
    name: 'Experience',
    link: '#services'
  },
  {
    name: 'Contact',
    link: '#contact'
  }
]
---

<nav class='fixed top-4 inset-x-0 w-full max-w-7xl mx-auto z-40'>
  <div
    class='flex justify-between items-center border border-gray-200 rounded-full py-2.5 text-white px-6 bg-white/10 backdrop-blur-sm'
  >
    <p class='font-medium text-xl'>GonSalmeron</p>

    <div class='flex items-center justify-end gap-4'>
      <Clock client:load />
      <span class='border-r border-gray-200 w-0.5 h-5'></span>
      <ul class='flex items-center gap-4'>
        {
          links.map(({ name, link }) => (
            <li>
              <a href={link}>{name}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>
